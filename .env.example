APP_NAME=LeadBot Studio
ENV=dev
DATABASE_URL=sqlite:///./leadbot_studio.db
TIMEZONE=Asia/Shanghai
LEADBOT_MANIFEST_PATH=app/data/leadbot_studio_manifest.json

# ===== Model Integration (LeadBot Draft) =====
# Provider: auto / openai / azure / openai-compatible / none (deterministic only)
LEADBOT_DRAFT_PROVIDER=auto
# Model name (e.g., gpt-4o, gpt-4o-mini, llama3.3-70b)
LEADBOT_DRAFT_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Azure OpenAI (alternative to OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_VERSION=2024-05-01-preview

# Local Model / OpenAI-compatible API (e.g., LM Studio, Ollama)
# When using local models, set OPENAI_API_KEY=local or any placeholder
# Example: OPENAI_BASE_URL=http://localhost:1234/v1
